APP_ENV=development
APP_NAME=scraper-service
API_HOST=0.0.0.0
API_PORT=8200
API_KEYS=scraper-geoserra-change-me
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=86400
DEFAULT_TIMEOUT_SECONDS=30
DEFAULT_RATE_LIMIT_PER_MINUTE=60
# Hard cap on concurrently launched browsers (RAM backstop, independent of arq max_jobs)
MAX_CONCURRENT_BROWSERS=2
# Per-step timeout for browser teardown so a hung Chrome cannot block pw.stop()
BROWSER_CLOSE_TIMEOUT_SECONDS=20
# Reaper: kill orphan Chromium older than this (must exceed arq job_timeout=600)
REAPER_MAX_AGE_SECONDS=900
LOG_LEVEL=info
PLACES_DAILY_QUOTA=200
PLACES_PROXY_URL=
# Lead Machine kota limitleri
LEAD_DAILY_QUOTA=500
DIRECTORY_DAILY_QUOTA=200
FAIR_DAILY_QUOTA=100
# Geo-bloklayan fuar siteleri icin proxy (istege bagli)
FAIR_PROXY_URL=
# VPS'te host nginx 80/443 kullaniyorsa: SKIP_COMPOSE_NGINX=1 (compose icindeki nginx baslamaz)
# SKIP_COMPOSE_NGINX=1
# Local smoke without Docker/Redis: REDIS_URL=memory://
